---
import { siteConfig } from "@/site.config";
import ThemeButton from "./ThemeButton.tsx";
---

<nav class="navbar has-shadow" role="navigation" aria-label="main navigation">
    <div class="navbar-brand">
        <a href="/" class="navbar-item">
            <img src="/favicon-64x64.png" alt="Miners Online Logo" style="max-height: 2.5rem;"/>
            <span class="ml-2 is-size-4">Miners Online</span>
        </a>
        <a role="button" class="navbar-burger" aria-label="menu" aria-expanded="false" data-target="mainNav">
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
        </a>
    </div>
    <div id="mainNav" class="navbar-menu">
        <div class="navbar-start">
            {siteConfig.topNavigation.map(link => (
                <a href={link.href} class="navbar-item">{link.name}</a>
            ))}
        </div>
        <div class="navbar-end">
            <ThemeButton/>
            <div class="navbar-item has-dropdown is-hoverable">
                <a class="navbar-link">Socials</a>
                <div class="navbar-dropdown">
                    {siteConfig.socials.map(link => (
                        <a href={link.href} class="navbar-item">{link.title}</a>
                    ))}
                </div>
            </div>
        </div>
    </div>
</nav>
