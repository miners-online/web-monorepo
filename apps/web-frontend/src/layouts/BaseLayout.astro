---
import globals from '@/globals';
import '@/style.css';

interface Props {
    title?: string;
}

const { title } = Astro.props;

const currentUrl = Astro.url.pathname;

const buildDate = new Date();
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />

        <title>{title || "Untitled"} | {globals.meta.siteName}</title>

        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
            rel="stylesheet"
            integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
            crossorigin="anonymous"
        />

        <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
        />

        <link rel="icon" type="image/png" sizes="256x256" href="https://github.com/miners-online/.github/blob/main/profile/logos/favicon-256x256.png?raw=true" />
        <link rel="icon" type="image/png" sizes="160x160" href="https://github.com/miners-online/.github/blob/main/profile/logos/favicon-160x160.png?raw=true" />
        <link rel="icon" type="image/png" sizes="64x64" href="https://github.com/miners-online/.github/blob/main/profile/logos/favicon-64x64.png?raw=true" />

        <slot name="head" />
    </head>

    <body class="d-flex flex-column bg-body-secondary">
        <header
            class:list={[
                "header",
                currentUrl === "/" && "header-clip"
            ]}
            style="background: linear-gradient(135deg, var(--blue-5), var(--blue-6), var(--green-5));"
        >
            <nav class="navbar navbar-expand-md navbar-dark py-3">
                <div class="container">
                    <a class="navbar-brand me-4" href="/">
                        {globals.meta.siteName}
                    </a>

                    <button
                        class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation"
                    >
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="mainNavbar">
                        <ul class="navbar-nav">
                            {globals.navigation.map((item) => (
                                <li class="nav-item">
                                    <a
                                        class:list={[
                                            "nav-link",
                                            item.url === currentUrl && "active"
                                        ]}
                                        href={item.url}
                                    >
                                        <i class={item.icon}></i> {item.title}
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </div>
                </div>
            </nav>

            <slot name="header" />
        </header>

        <slot />

        <footer class="footer text-bg-dark mt-auto py-4">
            <div class="container">
                <div class="row mt-3">
                    {globals.footer.columns.map((column) => (
                        <div class="col-md-3 mb-3">
                            <h5>{column.title}</h5>
                            <ul class="list-unstyled">
                                {column.links.map((link) => (
                                    <li>
                                        <a
                                            href={link.url}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                        >
                                            <i class={link.icon}></i> {link.title}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))}
                </div>

                <p class="text-center mb-0">
                    Miners Online - © Samuel Hulme 2017 - {buildDate.getFullYear()}. All rights reserved.
                </p>
            </div>
        </footer>

        <script
            src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"
        ></script>
    </body>
</html>