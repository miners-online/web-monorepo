---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import ArticleDisplay from "@/components/ArticleDisplay.astro";

const news = (await getCollection("news"))
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
    .slice(0, 4);

const servers = [
    {
        title: "Miners Online (Java Edition)",
        hostname: "play.minersonline.uk",
        port: 25565,
        version: "1.8-26.1.2"
    },
    {
        title: "Miners Online (Bedrock Edition)",
        hostname: "play.minersonline.uk",
        port: 19132,
        version: "1.8-26.1.2"
    }
];

const response = await fetch("https://api.mcsrvstat.us/3/play.minersonline.uk");
const data = await response.json();

export const prerender = false;
---

<BaseLayout title="Home">
    <!-- Hero Section -->
    <section class="hero d-flex align-items-center text-white" slot="header">
        <div class="container">
            <div class="row align-items-center">
                <!-- Left Content -->
                <div class="col-lg-6 text-center text-lg-start">
                    <h1 class="display-4 fw-bold mb-3 lh-1">
                        Join Miners Online today.
                        {data.online ? (
                            <span class="badge bg-success ms-2 fs-6 align-middle">
                                Online
                            </span>
                        ) : (
                            <span class="badge bg-danger ms-2 fs-6 align-middle">
                                Offline
                            </span>
                        )}
                    </h1>
                    <p class="lead mb-4">
                        Join our in development Minecraft server and compete in our farming, fishing, and mining competitions.
                        Explore our custom gameplay mechanics and enjoy a unique Minecraft experience. Join our community today!

                        <i>Farming, fishing, and mining competitions are coming soon!</i>
                    </p>

                    <div class="d-flex gap-3 justify-content-center justify-content-lg-start">
                        <a href="#play-now" class="btn btn-success btn-lg px-4">Play now</a>
                        <a href="#features" class="btn btn-outline-light btn-lg px-4">Explore Features</a>
                    </div>
                </div>

                <!-- Right Image Placeholder -->
                <div class="col-lg-6 text-center mt-5 mt-lg-0">
                    <div class="hero-image-placeholder mx-auto">
                        <span>Image Placeholder</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- News Section -->
    <section class="container my-2">
        <h2 class="text-center" id="news">
            News
        </h2>

        <div class="row g-3">
            <!-- Left big card -->
            <div class="col-12 col-lg-8">
                {news.length > 0 && (
                    <ArticleDisplay id={news[0].id} data={news[0].data} classes="h-100" />
                )}
            </div>

            <!-- Right stacked cards -->
            <div class="col-12 col-lg-4 d-flex flex-column gap-3">
                <!-- Strip the first article -->
                {news.slice(1).map((article) => (
                    <ArticleDisplay id={article.id} data={article.data} />
                ))}
            </div>
        </div>

        <!-- More news -->
        <div class="text-center mt-4">
            <a href="/news" class="btn btn-outline-primary">View all news</a>
        </div>
    </section>

    <!-- Play Now Section -->
    <section class="play-now bg-white" id="play-now">
        <div class="container">
            <h2 class="text-center mb-5">Play now</h2>

            {data.online ? (
                <div class="py-3 text-center">
                    <p class="mb-1">Server is online</p>
                    <div class="progress mb-1 mx-auto" style="width: 30%">
                        <div class="progress-bar" role="progressbar" style={`width: ${data.players.online / data.players.max * 100}%`}></div>
                    </div>
                    <p class="mb-1">{data.players.online}/{data.players.max} online players</p>
                </div>
            ) : (
                <p class="text-center">Server is offline</p>
            )}


            <div class="d-flex flex-column">
                {servers.map((server) => (
                    <div class="server-item">
                        <h3>{server.title}</h3>
                        <p>
                            <strong>Hostname:</strong> {server.hostname}<br>
                            <strong>Port:</strong> {server.port}<br>
                            <strong>Version:</strong> {server.version}
                        </p>
                    </div>
                ))}
            </div>
        </div>
    </section>
</BaseLayout>

<style>
.hero {
    min-height: 50vh;
    padding: 20px 0;
    overflow: hidden;
    padding-bottom: 6rem;
}

.hero-image-placeholder {
    width: 100%;
    max-width: 420px;
    aspect-ratio: 1 / 1;
    border-radius: 20px;
    border: 2px dashed rgba(255,255,255,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.7);
    font-weight: 500;
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(6px);
}

.play-now {
    padding: 5rem 0;
    clip-path: polygon(0 15%, 100% 0, 100% 85%, 0 100%);
}

.server-item {
    padding: 1rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.12);
}

.server-item:last-child {
    border-bottom: none;
}

.server-item h3 {
    margin: 0 0 0.35rem 0;
}

.server-item p {
    margin: 0;
}
</style>